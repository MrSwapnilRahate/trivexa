# Site Configuration
NEXT_PUBLIC_SITE_URL=https://trivexa.com
NEXT_PUBLIC_SITE_NAME=TRIVEXA
NEXT_PUBLIC_CONTACT_EMAIL=your_contact_email@example.com

# Web3Forms (Contact Form)
# Get your access key from https://web3forms.com
# Free tier: Unlimited submissions
# Steps: 1. Sign up 2. Create form 3. Copy access key 4. Add below
NEXT_PUBLIC_WEB3FORMS_KEY=your_web3forms_access_key_here

# Analytics (optional) — site renders without these; set to activate
# Google Analytics 4 measurement ID, format G-XXXXXXXXXX
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_VERCEL_ANALYTICS=true
